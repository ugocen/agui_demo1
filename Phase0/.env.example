# AWS_REGION: required by the backend to build AgentCore invocation URLs and to
# list runtimes. NOTE: agent *deployment* settings (BEDROCK_MODEL_ID, DEPLOY_BUCKET,
# EXECUTION_ROLE_ARN) are intentionally NOT here — agents are deployed out-of-band
# by CI/CD or manually, and the backend never reads those values.
AWS_REGION=

# --- Logging ----------------------------------------------------------------
# LOG_LEVEL: default DEBUG. LOG_FORMAT: `console` (default, human-readable) or
# `json` (one JSON object per line — for CloudWatch and other log collectors).
# LOG_LEVEL=DEBUG
# LOG_FORMAT=json

# --- Platform sign-in (Entra ID SSO) ----------------------------------------
# AUTH_MODE=iam  -> SSO OFF: no token validation, no roles, all routes open.
#                   The app runs exactly like before (use this for local dev;
#                   real Microsoft login cannot be automated). Same effect: off.
# AUTH_MODE=entra -> SSO ON: validate the caller via Microsoft Graph and derive
#                   platform roles from AD-group membership (see below).
AUTH_MODE=iam

# Single-tenant pin. The token's `tid` must equal this (rejects other tenants).
ENTRA_TENANT_ID=
# The SPA app-registration client id. Used to pin the token's `azp`/`appid`
# (confused-deputy guard). ENTRA_ALLOWED_CLIENT_IDS overrides/extends it (CSV).
ENTRA_SPA_CLIENT_ID=
ENTRA_ALLOWED_CLIENT_IDS=

# AD-group -> platform-role mapping. JSON object of {groupObjectId: roleName}.
# Roles are computed server-side from live membership; the client never asserts
# them. Leave empty for identity-only (authenticated but no role enforced).
# Example: {"11111111-1111-1111-1111-111111111111":"user","2222...":"admin"}
ENTRA_GROUP_ROLE_MAP=
# Admin AD group — members get the "admin" role. Set EITHER the object id OR the
# display name (or both). This is the primary AD-group-driven admin path.
ENTRA_ADMIN_GROUP_ID=
ENTRA_ADMIN_GROUP_NAME=
# Bootstrap admins by email (CSV), without an AD group — handy on a test tenant or
# before groups exist. Optional twin: ENTRA_ADMIN_OIDS (CSV of AAD object ids).
ENTRA_ADMIN_EMAILS=
ENTRA_ADMIN_OIDS=
# How long (seconds) to cache a user's group membership. Shorter = faster
# de-provisioning when someone is removed from a group. Default 300.
ENTRA_GROUPS_TTL_SECONDS=300
# Optional: role required to use the platform (the AG-UI proxy). Empty = any
# authenticated user. Set to a role name from ENTRA_GROUP_ROLE_MAP to restrict.
REQUIRED_ROLE=

# --- Database ---------------------------------------------------------------
# Platform DB (agent catalog, admin edits). Defaults to a local SQLite file
# (Phase0/backend/phase0.db) — no service needed. Point at Postgres for real
# deployments: postgresql+asyncpg://user:pass@host:5432/dbname
# DATABASE_URL=

# --- Agent runtimes ---------------------------------------------------------
# Nothing here. Agents are NOT configured via env. The catalog is populated
# purely by discovering live runtimes from the AgentCore control plane
# (ListAgentRuntimes) and storing them in the DB; the proxy routes on the DB
# entry's ARN. Deploy an agent to AgentCore (as an AG-UI runtime) in AWS_REGION
# and it appears automatically on the next catalog sync. Only AWS_REGION (above)
# plus AWS credentials on the host are required.
#
# The agents' own LLM-provider config (Amazon Bedrock vs the enterprise
# x-api-key gateway) is NOT read here either — it lives with the agents
# (Phase0/agents/.env.example) and is set as AgentCore runtime env at deploy
# time. The same agent code runs in both modes with no change; the enterprise
# overlay (cloud_deploy/) carries a filled-in gateway example.

# --- Secrets (never commit) ---
.env
.env.*
# Templates are safe and must stay tracked. `!.env.example` does NOT cover
# `.env.local.example` (the `.env.*` rule above matches it), so negate it too —
# otherwise the frontend package ships with no config template.
!.env.example
!.env.local.example
*.pem
*.key

# --- Python ---
__pycache__/
*.pyc
.venv/
venv/

# --- Node / Next.js ---
node_modules/
.next/

# --- Build / packaging artifacts ---
build/
dist/
*.zip

# --- Local databases ---
*.db
*.sqlite3

# --- OS / editor cruft ---
.DS_Store

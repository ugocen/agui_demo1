# Agent LLM config. Read by model_factory.py.
#
# Agents run on AgentCore, where these are set as runtime environment variables
# at deploy time. This file is only for LOCAL standalone agent testing: copy to
# `.env` (gitignored) — each agent auto-loads it at startup via python-dotenv,
# and real process env vars always take precedence.
#
# THESE AGENTS ARE AMAZON BEDROCK ONLY. There is no enterprise-gateway code path
# here, so BEDROCK_ENDPOINT_URL / BEDROCK_API_KEY do nothing — model_factory.py
# does not read them. The gateway build is a separate copy of the agents under
# ../../cloud_deploy/agents/ (AGENTS.md invariant 4).

# Model id. Default: Claude Haiku 4.5 global inference profile.
BEDROCK_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0

# Region for the Bedrock call, resolved through the standard AWS credential /
# config chain. Your credentials must have model access in this region.
AWS_REGION=us-east-1

# Local-run flag. Strands' OpenTelemetry span instrumentation crashes the local
# SSE stream, so `python agent.py` needs OTEL off — this turns it off. NEVER set
# it on an AgentCore runtime: there it would disable the traces that feed the
# runtime's otel-rt-logs stream and GenAI Observability. It is safe to leave here
# because .env is never packaged into the deployment zip.
LOCAL_DEV=1

# Frontend runtime configuration.
#
# Copy this file to `.env.local` (which is gitignored) and fill in the blanks:
#
#     cp .env.local.example .env.local
#
# IMPORTANT: these values are inlined into the JavaScript bundle when the dev
# server or the production build STARTS. Editing .env.local while `npm run dev`
# is running changes nothing — stop it and start it again (or re-run
# `npm run build`) for a change to take effect.
#
# Never put a secret in this file. Everything here ships to the browser.

# ---------------------------------------------------------------------------
# Auth mode: `entra` (Microsoft Entra ID sign-in) or `iam` (sign-in disabled).
#
# This MUST match the backend's AUTH_MODE. If this variable is missing, it
# defaults to `iam` and the app boots with sign-in silently turned OFF.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_AUTH_MODE=entra

# ---------------------------------------------------------------------------
# Where the FastAPI backend is reachable FROM THE BROWSER.
# Used for /api/me, /api/agents, /api/agentcore/runtimes and /api/admin/*.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Entra ID (SSO). Required when NEXT_PUBLIC_AUTH_MODE=entra.
#
# Both values come from YOUR enterprise Entra app registration (a SPA / public
# client with a redirect URI of http://localhost:3000). Ask whoever owns the
# tenant for them — the values below are placeholders, not real ids.
#
# NEXT_PUBLIC_ENTRA_SPA_CLIENT_ID must be IDENTICAL to the backend's
# ENTRA_SPA_CLIENT_ID: the backend pins the token's `azp` claim to that id, so a
# mismatch makes every request fail authorization.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_ENTRA_TENANT_ID=<fill-me: enterprise Entra tenant (directory) id>
NEXT_PUBLIC_ENTRA_SPA_CLIENT_ID=<fill-me: enterprise Entra SPA application (client) id>

# ---------------------------------------------------------------------------
# Optional. Microsoft Graph scopes requested at sign-in, comma-separated.
# Defaults to "User.Read", which is enough for the backend to call Graph /me and
# /me/checkMemberGroups. Widen it only if AD-group resolution needs more, e.g.
#   NEXT_PUBLIC_ENTRA_SCOPES=User.Read,GroupMember.Read.All
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_ENTRA_SCOPES=User.Read

# ---------------------------------------------------------------------------
# Optional. Only needed if the backend is NOT on http://localhost:8000.
#
# Chat traffic is proxied SERVER-SIDE by the Next.js route /api/copilotkit,
# which reads the NON-prefixed `BACKEND_URL` (not NEXT_PUBLIC_BACKEND_URL) and
# falls back to http://localhost:8000. If you change NEXT_PUBLIC_BACKEND_URL to
# a different host, set this to the same value or chat will break while the rest
# of the app keeps working.
# ---------------------------------------------------------------------------
# BACKEND_URL=http://localhost:8000

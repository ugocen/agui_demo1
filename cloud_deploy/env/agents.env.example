# Agent LLM config — J&J GenAI gateway (enterprise Bedrock is unavailable).
# Copy to `../agents/.env` (gitignored) and fill BEDROCK_API_KEY. Each agent
# auto-loads it at startup via python-dotenv; real process env vars take
# precedence.
#
# This file configures a LOCAL run of the enterprise agents. A DEPLOYED agent
# never sees it — .env is not packaged into the zip, so the same values must be
# entered as runtime environment variables in the AgentCore Console. See
# ../README.md.
#
# The three variables below marked REQUIRED are mandatory: the enterprise agents
# have no Amazon Bedrock fallback (AGENTS.md invariant 4) and raise RuntimeError
# at startup if any is missing.

# BASE gateway URL ONLY. Do NOT put the full "/model/<id>/invoke" path here —
# the Bedrock Runtime client (Strands / langchain) appends the operation path
# itself (e.g. /model/<id>/converse). botocore reconstructs the full invoke URL
# from BEDROCK_ENDPOINT_URL + BEDROCK_MODEL_ID.
BEDROCK_ENDPOINT_URL=https://genaiapigwna.jnj.com

# Injected as the `x-api-key` request header on every model call. Required.
BEDROCK_API_KEY=

# Bedrock model id as the gateway expects it (colon in v1:0 is fine).
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0

# NOT read by the agents. model_factory.py pins the gateway client's region to a
# non-routable placeholder on purpose, so that a lost endpoint_url fails closed
# instead of resolving a real AWS endpoint. This value is only for deploy tooling
# (S3 + the AgentCore control plane), so set it to the region you deploy into.
AWS_REGION=us-east-1

# Local-run flag. Strands' OpenTelemetry span instrumentation crashes the local
# SSE stream, so `python agent.py` needs OTEL off. NEVER set it on an AgentCore
# runtime — there it would disable the traces feeding otel-rt-logs and GenAI
# Observability. Safe here: .env is never packaged into the zip.
LOCAL_DEV=1

# true  -> agents stream tokens (Bedrock ConverseStream).
# false -> non-streaming Converse; AG-UI still streams (rebuilt locally).
# Set false if the gateway does NOT proxy converse-stream / invoke-with-response-stream.
BEDROCK_STREAMING=true

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build output
/.next/
/out/
/build
*.tsbuildinfo
next-env.d.ts

# Testing
/coverage

# Environment files — these hold per-environment config and must never be
# committed. The example template below is the exception and IS tracked.
.env
.env.*
!.env.local.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Editor / OS noise
.DS_Store
*.pem
.vscode/
.idea/

# Vercel / Next telemetry
.vercel

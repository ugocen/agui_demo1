# Backend configuration template.
#
#   cp .env.example .env      # then edit .env — never commit .env
#
# This file lists every environment variable the backend actually reads.
# Anything not listed here is not read by this service.
#
# Precedence: real process environment variables win over this file. The backend
# loads backend/.env at import time; in this standalone repo backend/.env IS the
# configuration file.
#
# Agent runtimes are deliberately absent from this file — see "Agent runtimes"
# at the bottom.


# --- CORS ---------------------------------------------------------------------
# Comma-separated list of allowed origins for browser requests. In a local dev
# setup where the frontend runs on localhost:3000, this can be left unset (the
# default is http://localhost:3000). On EKS or any deployment where the frontend
# hostname differs, set it to that hostname — otherwise the browser blocks
# every cross-origin request.
# CORS_ORIGINS=https://agui.enterprise.internal


# --- AWS ----------------------------------------------------------------------
# REQUIRED. The region whose Bedrock AgentCore control plane is listed for agents
# and whose runtimes are invoked. The backend refuses /api/agui and
# /api/agentcore/runtimes if this is empty.
#
# AWS *credentials* are not configured here. The backend uses the default boto3
# chain, so provide them inside WSL via ~/.aws/credentials, ~/.aws/config
# (SSO profile + AWS_PROFILE), or an instance/container role.
AWS_REGION=us-east-1


# --- Logging ------------------------------------------------------------------
# LOG_LEVEL: DEBUG (default) | INFO | WARNING | ERROR. DEBUG traces every request,
# auth decision and proxy hop — useful while bringing the service up, noisy after.
# LOG_LEVEL=INFO

# LOG_FORMAT: console (default, human-readable) | json (one JSON object per line,
# for a log collector such as CloudWatch or Splunk).
# LOG_FORMAT=json


# --- Layer A: browser -> backend authentication -------------------------------
# AUTH_MODE=iam    -> SSO OFF. No token validation, no roles, every route open.
#                    Use this for the first local smoke run: a real Microsoft
#                    login cannot be scripted, and iam mode lets you prove the
#                    backend, AgentCore and the agents work before adding SSO.
#                    "off" behaves identically.
# AUTH_MODE=entra  -> SSO ON. The caller's Microsoft Graph access token is
#                    validated and platform roles are derived server-side from
#                    live AD-group membership. This is the enterprise setting.
#
# IMPORTANT — entra mode fails closed. With AUTH_MODE=entra, ENTRA_TENANT_ID and
# at least one of ENTRA_SPA_CLIENT_ID / ENTRA_ALLOWED_CLIENT_IDS MUST be set, or
# every request returns HTTP 500 ("server misconfigured"). That is by design: no
# config must never mean "accept anything".
AUTH_MODE=entra

# REQUIRED in entra mode. Single-tenant pin: the token's `tid` claim must equal
# this exact tenant id. Rejects tokens from any other tenant.
ENTRA_TENANT_ID=

# REQUIRED in entra mode (this one or ENTRA_ALLOWED_CLIENT_IDS). The frontend SPA
# app-registration client id. Pins the token's `azp`/`appid` claim so a Graph
# token minted for some other app the user consented to is rejected
# (confused-deputy guard). Must match the client id the frontend signs in with.
ENTRA_SPA_CLIENT_ID=

# Optional. Comma-separated list of additional client ids allowed as `azp`/`appid`.
# When set, this list replaces ENTRA_SPA_CLIENT_ID as the allowlist.
# ENTRA_ALLOWED_CLIENT_IDS=

# Optional. AD group -> platform role mapping, as a JSON object of
# {groupObjectId: roleName}, on a single line. Group object ids are opaque GUIDs
# and are matched exactly. Roles are computed here from live membership — the
# browser never asserts its own roles.
# Leave empty for identity-only: users are authenticated but carry no role.
# Example:
# ENTRA_GROUP_ROLE_MAP={"11111111-1111-1111-1111-111111111111":"user","22222222-2222-2222-2222-222222222222":"admin"}
ENTRA_GROUP_ROLE_MAP=

# Optional. Members of this AD group get the "admin" role (access to /api/admin/*).
# Set the group's object id, or its exact display name, or both. This is the
# primary AD-group-driven admin path.
ENTRA_ADMIN_GROUP_ID=
ENTRA_ADMIN_GROUP_NAME=

# Optional bootstrap escape hatch: grant "admin" directly by email or by AAD
# object id (comma-separated), independent of any group. Useful before the AD
# groups exist. Remove once ENTRA_ADMIN_GROUP_ID / _NAME is in place.
ENTRA_ADMIN_EMAILS=
ENTRA_ADMIN_OIDS=

# Optional. Seconds to cache a caller's group membership (default 300). Lower =
# a user removed from a group loses access sooner, at the cost of more Microsoft
# Graph calls.
# ENTRA_GROUPS_TTL_SECONDS=300

# Optional. Role required to use the platform at all (the agent list and the
# AG-UI proxy). Empty = any authenticated user may use it. Set to a role name
# produced by ENTRA_GROUP_ROLE_MAP (e.g. "user") to restrict the platform to one
# group. The "admin" role for /api/admin/* is enforced separately and is not
# affected by this.
REQUIRED_ROLE=


# --- Database -----------------------------------------------------------------
# The platform DB holds the agent catalog and the admin audit log.
# Unset (default): a local SQLite file at backend/phase0.db, created on first
# start. No database service required.
# For EKS or any multi-replica deployment, point at PostgreSQL (asyncpg is
# already in requirements.txt):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname


# --- Agent runtimes -----------------------------------------------------------
# Nothing to configure here, by design.
#
# There is NO agent id and NO runtime ARN in this file. The backend discovers
# AG-UI-protocol runtimes directly from the Bedrock AgentCore control plane in
# AWS_REGION and stores them in the platform DB; the proxy routes on the DB
# entry's ARN. Deploy an agent to AgentCore and it appears automatically on the
# next catalog sync.
#
# Model/gateway settings (BEDROCK_ENDPOINT_URL, BEDROCK_API_KEY, BEDROCK_MODEL_ID)
# belong to the agents, not to this service. They live in the agents repo and are
# baked into each runtime at deploy time. The backend never reads them.

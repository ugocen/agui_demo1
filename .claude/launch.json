{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "Phase0/frontend", "run", "dev"],
      "port": 3000
    },
    {
      "name": "backend",
      "runtimeExecutable": "Phase0/backend/.venv/bin/uvicorn",
      "runtimeArgs": ["app.main:app", "--port", "8000", "--app-dir", "Phase0/backend"],
      "port": 8000
    }
  ]
}

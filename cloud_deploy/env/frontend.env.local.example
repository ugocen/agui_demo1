# Enterprise frontend runtime config. Copy to Phase0/frontend/.env.local
# (gitignored). NEXT_PUBLIC_* are inlined by Next.js at dev/build start —
# restart `npm run dev` after changing anything here.
#
# SSO on. Set NEXT_PUBLIC_AUTH_MODE=iam to turn SSO OFF (app runs like before).
# Keep this in sync with the backend's AUTH_MODE.
NEXT_PUBLIC_AUTH_MODE=entra
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Entra tenant + SPA app registration "agui-test". clientId MUST equal the
# backend's ENTRA_SPA_CLIENT_ID (the backend pins the token's azp to it).
NEXT_PUBLIC_ENTRA_TENANT_ID=98c18fba-5be5-4229-a075-90da42d85df3
NEXT_PUBLIC_ENTRA_SPA_CLIENT_ID=1528c934-6675-4e0d-a674-b78cc9dd0538

# Optional — defaults to "User.Read" (a Graph access token for /me +
# /me/checkMemberGroups). Add scopes (comma-separated) if group resolution needs
# a broader one, e.g. "User.Read,GroupMember.Read.All".
# NEXT_PUBLIC_ENTRA_SCOPES=User.Read

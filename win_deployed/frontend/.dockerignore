# Docker matches these with Go's filepath.Match, which is NOT recursive: a bare
# `node_modules/` matches only the build-context root, so a nested
# `src/**/node_modules` or a stray `.DS_Store` deeper in the tree would still be
# copied in. Every nested pattern therefore needs the `**/` prefix.

# Dependencies & build output
**/node_modules
.next/
out/

# Environment files (secrets — never in the image)
.env
.env.*
!.env.example
!.env.local.example

# Dev/agent tooling
.claude/
.agents/
CLAUDE.md
AGENTS.md

# IDE & OS
.vscode/
.idea/
**/.DS_Store

# Build artifacts
**/*.zip
**/*.tsbuildinfo

# Git
.git/
.gitignore
.gitattributes

# Docs
README.md

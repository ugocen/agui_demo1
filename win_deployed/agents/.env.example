# ============================================================================
# Agents configuration template
# ============================================================================
# Copy this file to `.env` in THIS folder and fill in the blanks:
#
#     cp .env.example .env
#
# This one file serves two purposes:
#
#   1. DEPLOY CONFIG    - read by `scripts/deploy_agent.py`. It supplies the AWS
#                         target (region, S3 bucket, execution role) and the
#                         values that get pushed onto the AgentCore runtime as
#                         its environment variables.
#   2. LOCAL MODEL CONFIG - read by each agent at startup via python-dotenv when
#                         you run an agent directly (`python agent.py`). See the
#                         "Run an agent locally" section of README.md.
#
# Precedence: real process environment variables always win over this file
# (agents call load_dotenv() with override=False).
#
# `.env` is listed in .gitignore. NEVER commit it, and never paste the API key
# into a ticket, chat message or screenshot.
# ============================================================================


# ---------------------------------------------------------------------------
# LLM PROVIDER - GenAI marketplace API gateway
# ---------------------------------------------------------------------------
# These agents talk to the GenAI marketplace gateway and NOTHING else. There is
# no Amazon Bedrock code path in them at all, and no fallback: model_factory.py
# raises RuntimeError at startup if any of the three variables below is missing.
# That is deliberate - this account has no Bedrock model access, so a silent
# fallback would be a failure disguised as a success.
#
# The same three values must ALSO be set as runtime environment variables on the
# AgentCore runtime itself (Console -> the runtime -> Environment variables).
# This file does not travel into the deployment zip; only the console values
# reach a deployed agent. This file is for running an agent locally, and for
# scripts/deploy_agent.py if you use it.
#
# If you forget one, the agent raises before its HTTP server binds, the runtime
# never passes its health check, and the invoke fails with an initialization
# timeout - which looks identical to a wrong-port bug. The real message is in the
# runtime's `[runtime-logs]` CloudWatch stream. See README.md.

# BASE URL ONLY. Do NOT append a path.
# botocore builds the full path itself, e.g. /model/<BEDROCK_MODEL_ID>/converse.
# Adding "/model/..." or "/converse" here is the most common setup mistake and
# produces 404s from the gateway.
BEDROCK_ENDPOINT_URL=https://genaiapigwna.jnj.com

# Injected as the `x-api-key` header on every model call. REQUIRED - leave blank
# here and fill it in your local `.env` only.
BEDROCK_API_KEY=

# Model id exactly as the gateway expects it (the colon in "v1:0" is correct).
# REQUIRED - there is no default in the enterprise build.
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0

# true  -> agents stream tokens from the model (Bedrock ConverseStream).
# false -> single-shot Converse. The UI still streams either way: AG-UI rebuilds
#          the token stream locally.
# Set this to false if the gateway does not proxy converse-stream.
BEDROCK_STREAMING=true


# ---------------------------------------------------------------------------
# AWS - deploy target (scripts/deploy_agent.py)
# ---------------------------------------------------------------------------
# Requires AWS credentials available inside WSL (~/.aws/credentials or exported
# environment variables) with access to S3 and bedrock-agentcore-control.

# In gateway mode this region is only used for the (ignored) SigV4 signature
# scope on model calls, but deploy_agent.py also uses it to target S3 and the
# AgentCore control plane - so set it to the region you deploy into.
AWS_REGION=us-east-1

# S3 bucket for the deployment zips. deploy_agent.py uploads to
# s3://<DEPLOY_BUCKET>/<agent-name>/deployment_package.zip and creates the
# bucket if it does not exist.
DEPLOY_BUCKET=

# IAM role ARN the AgentCore runtime assumes at execution time.
# Format: arn:aws:iam::<account-id>:role/<role-name>
EXECUTION_ROLE_ARN=


# ---------------------------------------------------------------------------
# AgentCore runtime inbound auth - who is allowed to call the runtime
# ---------------------------------------------------------------------------
# Chosen PER AGENT by deploy_agent.py, never by a setting in this file. A
# runtime is EITHER IAM-authorized or JWT-authorized:
#
#   iam (default) -> no inbound authorizer. The backend proxy SigV4-signs the
#                    call and the agent never learns who asked.
#   jwt           -> AgentCore validates the caller's own Entra token against
#                    the tenant's OIDC discovery document before the agent
#                    runs, and the proxy forwards that token instead of signing.
#
# The list is JWT_AUTH_AGENTS in scripts/deploy_agent.py - currently just
# whoami-strands, the identity-aware reference agent. Override for one deploy
# with `--auth=iam|jwt`.
#
# AUTH_MODE is NOT read by the deploy script. It is the backend's browser
# sign-in setting, and deriving the runtime's inbound auth from it flipped EVERY
# runtime to JWT the moment SSO was switched on - leaving the SigV4 agents
# rejecting the very proxy that routes to them.

# REQUIRED to deploy a jwt agent (harmless and unused for the iam ones): the
# discovery URL is derived from the tenant id, and the audience defaults to the
# SPA client id because the browser sends an Entra ID token whose `aud` is
# exactly that. Without them the deploy exits with a FAIL naming the missing
# one. Same two values the backend uses - copy them from the backend's .env.
ENTRA_TENANT_ID=
ENTRA_SPA_CLIENT_ID=

# Optional explicit overrides for the above. Set ENTRA_ALLOWED_AUDIENCE only if
# you switched the app registration to an "Expose an API" access token
# (`api://<client-id>`); that also needs `accessTokenAcceptedVersion: 2` in the
# app manifest, or Entra issues a v1 token whose issuer never matches the v2.0
# discovery document and is rejected with no useful error.
#ENTRA_DISCOVERY_URL=
#ENTRA_ALLOWED_AUDIENCE=
#ENTRA_ALLOWED_CLIENTS=

# Optional, only for an agent that reads the caller's Microsoft Graph profile
# through an AgentCore Identity OBO provider. Passed to the runtime unchanged.
#GRAPH_OBO_PROVIDER_NAME=
#GRAPH_OBO_SCOPES=


# ---------------------------------------------------------------------------
# Agent runtimes - no ARN belongs in this file
# ---------------------------------------------------------------------------
# There is no runtime ARN here and nothing writes one back. An earlier version
# of deploy_agent.py appended one per agent (PLANNER_RUNTIME_ARN and friends);
# it no longer does, and any such line left in an old `.env` is dead config.
#
# The catalog is their only home: the backend discovers AGUI-protocol runtimes
# from the AgentCore control plane in AWS_REGION, stores them in the platform DB
# (backend/phase0.db, table agent_catalog), and the proxy routes on the DB
# entry's runtime_arn. Deploy an agent and it appears on the next catalog sync -
# there is no per-agent backend or frontend configuration to add.


# ---------------------------------------------------------------------------
# OPTIONAL - where deploy_agent.py reads that catalog
# ---------------------------------------------------------------------------
# The deploy resolves its target CATALOG-FIRST: it updates the runtime the live
# app actually routes to, rather than one derived from the agent's name. That
# matters because several runtimes were created under names the convention
# cannot derive (e.g. Planner-QIXryP8Qvh for sdlc-planner-strands); deploying by
# convention updates a same-named twin the app never calls, and the app stays on
# stale code while the deploy reports success.
#
# It looks for the backend's SQLite file at `backend/phase0.db` relative to this
# folder. In this delivery the backend is a SEPARATE repository, so that path
# does not exist and the deploy falls back to the name convention with a
# "Catalog DB not found" line. Point this at the backend checkout's phase0.db to
# get catalog-first resolution:
#
#   CATALOG_DB_PATH=/home/<you>/agui-backend/phase0.db
#
# A Postgres catalog (backend DATABASE_URL) cannot be read here at all. With
# either fallback in play, check the ARN the deploy prints against the /admin
# catalog screen before trusting the deploy.
#CATALOG_DB_PATH=

# Docker matches these with Go's filepath.Match, which is NOT recursive: a bare
# `__pycache__/` matches only the build-context root, so `app/__pycache__/` and
# `alembic/versions/__pycache__/` would still be copied into the image. Every
# nested pattern therefore needs the `**/` prefix.

# Dependencies & build artifacts
.venv/
**/__pycache__
**/*.pyc
**/*.pyo

# Local databases (never bake into the image)
**/*.db
**/*.sqlite3

# Environment files (secrets — never in the image)
.env
.env.*

# Dev/agent tooling
.claude/
.agents/
CLAUDE.md
AGENTS.md

# IDE & OS
.vscode/
.idea/
**/.DS_Store

# Build output
build/
**/*.zip

# Git
.git/
.gitignore
.gitattributes

# Docs
README.md

# Agent LLM config (per-agent model provider). Read by model_factory.py.
#
# Agents run on AgentCore, where these are set as runtime environment variables
# at deploy time. This file is only for LOCAL standalone agent testing: copy to
# `.env` (gitignored) — each agent auto-loads it at startup via python-dotenv,
# and real process env vars always take precedence.
#
# TWO PROVIDERS, selected purely by env (single agent codebase, no code change):
#
#  * Default (personal / AgentCore) — leave BEDROCK_ENDPOINT_URL and
#    BEDROCK_API_KEY EMPTY. Model calls go to Amazon Bedrock with the host's
#    default AWS credential chain (SigV4).
#
#  * Enterprise gateway — set BOTH BEDROCK_ENDPOINT_URL and BEDROCK_API_KEY.
#    Model calls go to a Bedrock-Runtime-compatible API gateway that
#    authenticates with an `x-api-key` header instead of SigV4. See the
#    enterprise overlay (../../cloud_deploy/env/agents.env.example) for a
#    filled-in example.

# Model id. Default: Claude Haiku 4.5 global inference profile.
BEDROCK_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0

# Gateway BASE URL only (no /model/<id>/invoke path — the Bedrock Runtime client
# appends the operation path itself). Set WITH BEDROCK_API_KEY to enable gateway
# mode; leave empty for the default Bedrock path.
BEDROCK_ENDPOINT_URL=

# Injected as the `x-api-key` header on every model call in gateway mode.
BEDROCK_API_KEY=

# Region string. Default us-east-1. In gateway mode it is only the (ignored)
# SigV4 scope, since auth is via x-api-key.
AWS_REGION=us-east-1

# true  -> stream tokens (Bedrock ConverseStream).
# false -> non-streaming Converse; AG-UI still streams (rebuilt locally). Set
#          false if the gateway does not proxy converse-stream.
BEDROCK_STREAMING=true

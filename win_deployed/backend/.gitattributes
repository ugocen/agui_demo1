# Normalize line endings. These repos are cloned on Windows but the code runs in
# WSL2 (Ubuntu): a shell script checked out with CRLF fails with
# "bad interpreter: /bin/bash^M". Force LF for everything text.
* text=auto eol=lf

# Be explicit for the file types that break loudest with CRLF.
*.sh      text eol=lf
*.py      text eol=lf
*.ini     text eol=lf
*.cfg     text eol=lf
*.toml    text eol=lf
*.txt     text eol=lf
*.md      text eol=lf
*.json    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
.env*     text eol=lf

# Binary — never touch these.
*.db      binary
*.sqlite3 binary
*.zip     binary
*.png     binary
*.jpg     binary
*.ico     binary
